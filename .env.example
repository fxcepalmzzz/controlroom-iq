# ControlRoom IQ environment example
# Copy this file to .env for local development.
# Do not commit real secrets.

# Backend
CONTROLROOM_IQ_ENV=local
CONTROLROOM_IQ_DATA_MODE=synthetic
CONTROLROOM_IQ_BACKEND_HOST=127.0.0.1
CONTROLROOM_IQ_BACKEND_PORT=8000

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# Future Microsoft Foundry / Foundry IQ placeholders
# These are intentionally blank placeholders for the planned integration.
FOUNDRY_ENDPOINT=
FOUNDRY_PROJECT_NAME=
FOUNDRY_MODEL_DEPLOYMENT=
FOUNDRY_API_KEY=
FOUNDRY_IQ_KNOWLEDGE_SOURCE=
FOUNDRY_IQ_INDEX_NAME=

# Safety mode
# Keep true for hackathon demo unless a real secured Foundry integration is added.
USE_SYNTHETIC_DATA=true
ALLOW_REAL_ENTERPRISE_DATA=false
ALLOW_AUTONOMOUS_ACTIONS=false